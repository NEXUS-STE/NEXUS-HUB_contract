# ─────────────────────────────────────────────
#   NEXUS-HUB — Environment Variables Template
# ─────────────────────────────────────────────

# App
NODE_ENV=development
APP_PORT=4000

# JWT Auth
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# Database (PostgreSQL)
DATABASE_URL="postgresql://nexushub:nexushub_secret@localhost:5432/nexushub_db"
POSTGRES_USER=nexushub
POSTGRES_PASSWORD=nexushub_secret
POSTGRES_DB=nexushub_db

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Airtm
AIRTM_API_URL=https://api.airtm.com
AIRTM_API_KEY=your_airtm_api_key
AIRTM_WEBHOOK_SECRET=your_airtm_webhook_secret

# Trustless Work (Stellar Escrow)
TRUSTLESS_WORK_API_URL=https://api.trustlesswork.com
TRUSTLESS_WORK_API_KEY=your_trustless_work_api_key
STELLAR_NETWORK=testnet

# Webhooks
WEBHOOK_SIGNING_SECRET=your_webhook_signing_secret_change_in_production

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

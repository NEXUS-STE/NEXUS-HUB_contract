// packages/database/prisma/schema.prisma
// NEXUS-HUB — Full Database Schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  CLIENT
  FREELANCER
  MARKETPLACE
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum TransactionType {
  TOPUP
  PAYMENT
  WITHDRAWAL
  ESCROW_LOCK
  ESCROW_RELEASE
  ESCROW_REFUND
  FEE
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum EscrowStatus {
  PENDING
  FUNDED
  ACTIVE
  DISPUTED
  RELEASED
  REFUNDED
  CANCELLED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_CLIENT
  RESOLVED_FREELANCER
  CLOSED
}

enum DisputeReason {
  WORK_NOT_DELIVERED
  QUALITY_NOT_AS_AGREED
  PAYMENT_ISSUE
  FRAUD
  OTHER
}

enum WebhookEvent {
  TOPUP_COMPLETED
  TOPUP_FAILED
  PAYMENT_COMPLETED
  ESCROW_FUNDED
  ESCROW_RELEASED
  ESCROW_REFUNDED
  ESCROW_EXPIRED
  MILESTONE_COMPLETED
  WITHDRAWAL_COMPLETED
  WITHDRAWAL_FAILED
  DISPUTE_OPENED
  DISPUTE_RESOLVED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  passwordHash  String
  role          UserRole   @default(CLIENT)
  status        UserStatus @default(PENDING_VERIFICATION)
  firstName     String
  lastName      String
  airtmAccountId           String?  @unique
  stellarPublicKey         String?  @unique
  stellarSecretEncrypted   String?

  balance       Balance?
  transactions  Transaction[]
  clientEscrows  Escrow[]      @relation("EscrowClient")
  freelancerEscrows Escrow[]   @relation("EscrowFreelancer")
  disputesRaised Dispute[]    @relation("DisputeRaisedBy")
  auditLogs     AuditLog[]
  webhookEndpoints WebhookEndpoint[]
  refreshTokens RefreshToken[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Balance {
  id              String  @id @default(uuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  availableAmount Decimal @default(0) @db.Decimal(18, 6)
  reservedAmount  Decimal @default(0) @db.Decimal(18, 6)
  currency        String  @default("USD")
  version         Int     @default(0)  // Optimistic locking

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("balances")
}

model Transaction {
  id              String            @id @default(uuid())
  idempotencyKey  String            @unique
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  type            TransactionType
  status          TransactionStatus @default(PENDING)
  amount          Decimal           @db.Decimal(18, 6)
  fee             Decimal           @default(0) @db.Decimal(18, 6)
  currency        String            @default("USD")
  description     String?
  metadata        Json?
  reference       String?           // External reference (Airtm, Stellar tx hash, etc.)
  escrowId        String?
  escrow          Escrow?           @relation(fields: [escrowId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([idempotencyKey])
  @@map("transactions")
}

model Escrow {
  id                  String       @id @default(uuid())
  clientId            String
  client              User         @relation("EscrowClient", fields: [clientId], references: [id])
  freelancerId        String
  freelancer          User         @relation("EscrowFreelancer", fields: [freelancerId], references: [id])
  amount              Decimal      @db.Decimal(18, 6)
  fee                 Decimal      @default(0) @db.Decimal(18, 6)
  currency            String       @default("USD")
  status              EscrowStatus @default(PENDING)
  description         String
  milestoneTitle      String?
  milestoneHash       String?
  stellarContractId   String?      @unique
  stellarTxHash       String?

  // Mirror of on-chain EscrowRecord fields kept in sync by the worker
  milestonesTotal     Int          @default(0)
  milestonesCompleted Int          @default(0)
  expiryLedger        Int          @default(0)
  clientApproved      Boolean      @default(false)
  freelancerApproved  Boolean      @default(false)

  transactions        Transaction[]
  dispute             Dispute?

  releasedAt          DateTime?
  refundedAt          DateTime?
  fundedAt            DateTime?
  expiredAt           DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([clientId])
  @@index([freelancerId])
  @@index([status])
  @@map("escrows")
}

model Dispute {
  id           String        @id @default(uuid())
  escrowId     String        @unique
  escrow       Escrow        @relation(fields: [escrowId], references: [id])
  raisedById   String
  raisedBy     User          @relation("DisputeRaisedBy", fields: [raisedById], references: [id])
  reason       DisputeReason
  status       DisputeStatus @default(OPEN)
  description  String
  evidence     Json?         // Array of evidence URLs/notes
  resolution   String?
  resolvedAt   DateTime?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@map("disputes")
}

model WebhookEndpoint {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url        String
  secret     String
  events     WebhookEvent[]
  isActive   Boolean  @default(true)
  description String?

  deliveries WebhookDelivery[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id          String                @id @default(uuid())
  endpointId  String
  endpoint    WebhookEndpoint       @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  event       WebhookEvent
  payload     Json
  status      WebhookDeliveryStatus @default(PENDING)
  responseCode Int?
  responseBody String?
  attempts    Int                   @default(0)
  nextRetryAt DateTime?
  deliveredAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([endpointId])
  @@index([status])
  @@map("webhook_deliveries")
}

model AuditLog {
  id         String  @id @default(uuid())
  userId     String?
  user       User?   @relation(fields: [userId], references: [id])
  action     String
  entity     String
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  metadata   Json?

  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
